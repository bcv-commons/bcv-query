# Per-host config for deploy/deploy.sh.
#   cp deploy/deploy.local.env.example deploy/deploy.local.env   (the real one is gitignored)
# and set the paths to YOUR host. NO secrets belong here — those live in each
# stack's .env (referenced by its compose env_file).

# Directory holding each service's compose file (docker-compose.yml):
BCV_RAG_STACK=/opt/bcv-query
SHORESH_STACK=/opt/shoresh

# Optional overrides (defaults shown):
# BCV_RAG_IMAGE=bcv-commons/bcv-rag:latest
# SHORESH_IMAGE=shoresh:latest
# SEARCH_EMBEDDER=berel
