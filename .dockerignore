# Build context = repo ROOT (build with: docker build -f bcv-RAG/Dockerfile .).
# The Dockerfile only COPYs bcv-RAG/{indexer,ingest,query,server,corpus,
# resource_paths.py, */requirements.txt} and resources/. Everything else is
# excluded so the context stays small (~5 GB → ~30 MB).

# version control / tooling
.git
.github
.gitignore
**/.claude
**/.codex
**/.agents
**/.wrangler
**/node_modules

# examples / docs — not part of any image
example/
internal-docs/
# NOTE: shoresh/ is intentionally NOT excluded — both bcv-RAG and shoresh build
# from this repo-root context (shoresh via `-f shoresh/Dockerfile`) so the shared
# single-source-of-truth resources/ is reachable. bcv-RAG's Dockerfile COPYs only
# its own dirs, so including shoresh source here just adds a few MB of context it
# ignores. shoresh's heavy bits (spine.db/lxx.db, clause .npy, BEREL models) are
# already excluded below / built into shoresh-base.

# virtualenvs / caches / build junk
**/.venv
**/venv
**/.cache
**/.pytest_cache
**/__pycache__
**/*.pyc
**/.DS_Store

# big generated/data files (built locally or volume-mounted, never shipped)
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm
**/*.npy

# resources/strongs/ is the PUBLISHED open dataset (bcv-commons/strongs) —
# re-derivable, published to Hugging Face, and NOT read at runtime (verified:
# no resource_path("strongs") anywhere). ~443 MB — never ship it in the image.
resources/strongs/
# topic_strongs.tsv: topic-anchoring foundation, not yet wired into runtime
# (dormant). Re-include here once the gloss-bridge actually reads it. ~11 MB.
resources/topic_strongs.tsv

# bcv-RAG bits not needed in the image
bcv-RAG/scripts/
bcv-RAG/tools/
bcv-RAG/ingest/_staging/
bcv-RAG/Dockerfile
bcv-RAG/README.md
bcv-RAG/.dockerignore
